{
  "name": "saru-visas-backend",
  "version": "1.0.0",
  "description": "Backend API for Saru Visas - Visa Management System",
  "main": "dist/server.js",
  "scripts": {
    "generate-openapi": "node scripts/generate-openapi.js",
    "dev": "npm run generate-openapi && nodemon",
    "build": "tsc",
    "start": "npm run generate-openapi && node dist/server.js",
    "migrate": "sequelize-cli db:migrate",
    "migrate:undo": "sequelize-cli db:migrate:undo",
    "migrate:pg": "sequelize-cli db:migrate --config src/config/database-pg.js --migrations-path src/migrations-pg",
    "migrate:pg:undo": "sequelize-cli db:migrate:undo --config src/config/database-pg.js --migrations-path src/migrations-pg",
    "seed": "sequelize-cli db:seed:all",
    "seed:undo": "sequelize-cli db:seed:undo:all"
  },
  "keywords": [
    "express",
    "mysql",
    "sequelize",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/multer": "^2.1.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "mysql2": "^3.6.5",
    "pdf-lib": "^1.17.1",
    "pg": "^8.18.0",
    "sequelize": "^6.35.2",
    "swagger-ui-express": "^5.0.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "nodemon": "^3.0.2",
    "sequelize-cli": "^6.6.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
